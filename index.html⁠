<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>信用卡回饋助手</title>
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #1c1c1e;
            --card-border: #2c2c2e;
            --accent-color: #0a84ff;
            --text-primary: #ffffff;
            --text-secondary: #8e8e93;
            --success-color: #30d158;
            --warning-color: #ffd60a;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            padding: 20px 16px 40px;
            max-width: 500px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 24px;
            padding-top: 10px;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 14px;
            margin-top: 4px;
        }

        .section-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .input-group {
            margin-bottom: 16px;
        }

        .input-group:last-child {
            margin-bottom: 0;
        }

        label {
            display: block;
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input, select {
            width: 100%;
            background: #2c2c2e;
            border: 1px solid #3a3a3c;
            color: var(--text-primary);
            padding: 14px 16px;
            border-radius: 12px;
            font-size: 17px;
            outline: none;
            transition: border-color 0.2s;
        }

        input:focus, select:focus {
            border-color: var(--accent-color);
        }

        .result-box {
            background: linear-gradient(135deg, #1c2a3a 0%, #1c1c1e 100%);
            border: 1px solid #2a4365;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            margin-bottom: 20px;
        }

        .result-title {
            font-size: 14px;
            color: var(--text-secondary);
        }

        .result-amount {
            font-size: 36px;
            font-weight: 800;
            color: var(--success-color);
            margin: 8px 0;
        }

        .result-detail {
            font-size: 13px;
            color: #a0aec0;
        }

        .preset-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-top: 10px;
        }

        .preset-btn {
            background: #2c2c2e;
            border: 1px solid #3a3a3c;
            color: var(--text-primary);
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
        }

        .preset-btn.active {
            background: var(--accent-color);
            border-color: var(--accent-color);
        }

        footer {
            text-align: center;
            color: var(--text-secondary);
            font-size: 12px;
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <header>
        <h1>💳 信用卡回饋助手</h1>
        <p class="subtitle">即時計算最佳刷卡方案與回饋金額</p>
    </header>

    <div class="section-card">
        <div class="input-group">
            <label for="amount">消費金額 (NT$)</label>
            <input type="number" id="amount" placeholder="請輸入金額，例如：1500" value="1000" oninput="calculate()">
        </div>

        <div class="input-group">
            <label>快速選擇情境 / 卡片切換</label>
            <div class="preset-grid">
                <button class="preset-btn active" onclick="setRate(3, this)">CUBE 玩數位 (3%)</button>
                <button class="preset-btn" onclick="setRate(3.3, this)">CUBE 趣旅行 (3.3%)</button>
                <button class="preset-btn" onclick="setRate(3, this)">CUBE 樂饗購 (3%)</button>
                <button class="preset-btn" onclick="setRate(2, this)">通用海外回饋 (2%)</button>
            </div>
        </div>

        <div class="input-group" style="margin-top: 16px;">
            <label for="customRate">自訂回饋率 (%)</label>
            <input type="number" id="customRate" step="0.1" value="3.0" oninput="calculateFromCustom()">
        </div>
    </div>

    <div class="result-box">
        <div class="result-title">預估可獲得回饋</div>
        <div class="result-amount" id="rewardResult">30 小樹點 / 元</div>
        <div class="result-detail" id="rewardDetail">實際結算金額 NT$ 1,000 × 3%</div>
    </div>

    <footer>
        <p>iOS 風格極簡版 · 點擊 Safari 「分享」➔「加入主畫面」即可當作 App 使用</p>
    </footer>

    <script>
        let currentRate = 3.0;

        function setRate(rate, btn) {
            currentRate = rate;
            document.getElementById('customRate').value = rate;
            
            const btns = document.querySelectorAll('.preset-btn');
            btns.forEach(b => b.classList.remove('active'));
            if(btn) btn.classList.add('active');
            
            calculate();
        }

        function calculateFromCustom() {
            const val = parseFloat(document.getElementById('customRate').value);
            currentRate = isNaN(val) ? 0 : val;
            
            const btns = document.querySelectorAll('.preset-btn');
            btns.forEach(b => b.classList.remove('active'));
            
            calculate();
        }

        function calculate() {
            const amountInput = document.getElementById('amount');
            const amount = parseFloat(amountInput.value) || 0;
            
            const reward = Math.round(amount * (currentRate / 100));
            
            document.getElementById('rewardResult').innerText = reward.toLocaleString() + ' 元 / 點';
            document.getElementById('rewardDetail').innerText = `以消費金額 NT$ ${amount.toLocaleString()} × ${currentRate}% 計算`;
        }

        // 初始化計算
        calculate();
    </script>
</body>
</html>
